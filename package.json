{
  "name": "schemap",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,worker,dash -c blue,yellow,magenta \"npm:dev:api\" \"npm:dev:worker\" \"npm:dev:dashboard\"",
    "dev:api": "npm run dev -w @schemap/api",
    "dev:worker": "npm run dev -w @schemap/worker",
    "dev:dashboard": "npm run dev -w @schemap/dashboard",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate -w @schemap/core",
    "db:migrate": "npm run db:migrate -w @schemap/core"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  }
}
