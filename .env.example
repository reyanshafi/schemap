# Copy to .env and fill in. Defaults match docker-compose.yml for local dev.

DATABASE_URL=postgres://schemap:schemap@localhost:5432/schemap
REDIS_URL=redis://localhost:6379

# Object storage (MinIO locally, Cloudflare R2 in prod)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=schemap
S3_SECRET_KEY=schemap-secret
S3_BUCKET=schemap-uploads

# AI mapping (packages/ai) — leave empty to force the string-similarity fallback in dev
ANTHROPIC_API_KEY=

# 32-byte base64 key for AES-256-GCM encryption of webhook/embed secrets.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=

API_PORT=4000

# CORS origin the API trusts for dashboard session cookies
DASHBOARD_ORIGIN=http://localhost:3000
# where the dashboard finds the API (NEXT_PUBLIC_ = exposed to the browser)
NEXT_PUBLIC_API_URL=http://localhost:4000
